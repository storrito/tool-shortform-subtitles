#!/usr/bin/env bb
(require '[babashka.cli :as cli]
         '[babashka.fs :as fs]
         '[babashka.process :as p]
         '[clojure.string :as str])

(def image-name "storrito-shortform-subtitles:local")

(defn root-dir []
  (-> *file* fs/path fs/parent fs/absolutize fs/normalize))

(defn sh!
  [& args]
  (println "+" (str/join " " (map str args)))
  (let [{:keys [exit]} (apply p/shell {:continue true} (map str args))]
    (when-not (zero? exit)
      (throw (ex-info "Command failed" {:exit exit :command args})))))

(defn sh-out [& args]
  (-> (apply p/shell {:out :string :continue true} (map str args)) :out str/trim))

(defn die! [message]
  (binding [*out* *err*]
    (println message))
  (System/exit 1))

(defn usage []
  (println "Usage: ./render <params.edn>"))

(defn absolute-path [path]
  (-> path fs/path fs/absolutize fs/normalize str))

(defn output-dir [params-path]
  (str (fs/path (fs/parent (fs/path params-path)) "frames")))

(defn docker-run-args [params frames-dir]
  (let [params-parent (absolute-path (str (fs/parent (fs/path params))))
        output-parent (absolute-path (str (fs/parent (fs/path frames-dir))))]
    ["docker" "run" "--rm"
     "-e" (str "HOST_UID=" (sh-out "id" "-u"))
     "-e" (str "HOST_GID=" (sh-out "id" "-g"))
     "-v" (str params-parent ":/mnt/input:ro")
     "-v" (str output-parent ":/mnt/output")
     image-name
     "--params" (str "/mnt/input/" (fs/file-name params))
     "--frames-dir" (str "/mnt/output/" (fs/file-name frames-dir))]))

(defn -main [& argv]
  (let [{:keys [args opts]} (cli/parse-args argv {:spec {:help {:alias :h :coerce :boolean}}})
        [params & extra] args]
    (when (:help opts)
      (usage)
      (System/exit 0))
    (when (or (nil? params) (seq extra))
      (usage)
      (die! "Expected exactly: <params.edn>"))
    (let [params-path (absolute-path params)
          frames-dir (absolute-path (output-dir params-path))]
      (when-not (fs/exists? params-path)
        (die! (str "Params file does not exist: " params-path)))
      (sh! "docker" "build" "-t" image-name (str (root-dir)))
      (apply sh! (docker-run-args params-path frames-dir))
      (println "Wrote" frames-dir))))

(try
  (apply -main *command-line-args*)
  (catch Exception e
    (binding [*out* *err*]
      (println "Error:" (.getMessage e)))
    (System/exit 1)))
